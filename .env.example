# Groq (LLM inference — OpenAI-compatible chat completions)
GROQ_API_KEY=gsk_...          # console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile   # any Groq production chat model

# Database
DATABASE_URL=postgresql://synthex:synthex@localhost:5432/synthex

# Redis
REDIS_URL=redis://localhost:6379

# Search APIs
SERPER_API_KEY=...
VOYAGE_API_KEY=...           # voyageai.com — embeddings (voyage-large-2, 1536-dim)

# Agent tuning
MAX_RESEARCHER_AGENTS=3
MAX_REQUERY_ROUNDS=3
CRITIC_CONFIDENCE_THRESHOLD=0.7

# Voyage embeddings rate limit. All embedding requests are serialized and spaced
# at least this many ms apart to stay under Voyage's free tier (~3 req/min).
# Lower this (e.g. 2000) if your Voyage key has a higher rate limit — jobs finish
# much faster. Raise it if you still see 429s.
VOYAGE_MIN_INTERVAL_MS=21000

# Frontend
VITE_API_URL=http://localhost:3000

# CORS — the origin the browser frontend is served from (allowed by the API)
WEB_ORIGIN=http://localhost:5173

# SSE watchdog — how long (ms) the client waits with no events before declaring
# the job stalled and showing an error banner (default 30s)
VITE_SSE_STALL_TIMEOUT_MS=30000
