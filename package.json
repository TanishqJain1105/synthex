{
  "name": "synthex",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "src",
    "web",
    "shared"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=src",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspace=shared && npm run build --workspace=src && npm run build --workspace=web"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "msgpackr-extract@3.0.4": true
  }
}
